# Backend Environment Variables for Render.com

# Server Configuration
PORT=5000
NODE_ENV=production
ALLOWED_ORIGINS=https://your-frontend-url.com,http://localhost:3000

# SerpAPI (for News)
SERP_API_KEY=your_serp_api_key

# Groq (for AI)
GROQ_API_BASE=https://api.groq.com/openai/v1
GROQ_CHAT_MODEL=llama-3.1-8b-instant
GROQ_CODING_MODEL=llama-3.3-70b-versatile
GROQ_COMPOUND_MODEL=groq/compound-mini
GROQ_CHAT_API_KEY=your_groq_api_key
GROQ_CODING_API_KEY=your_groq_coding_api_key
GROQ_COMPOUND_API_KEY=your_groq_compound_api_key

# Timezone
JARVIS_TIMEZONE=Asia/Kolkata

# WeatherAPI
JARVIS_WEATHER_PROVIDER=weatherapi
JARVIS_WEATHER_API_BASE=https://api.weatherapi.com/v1
JARVIS_WEATHER_API_KEY=your_weatherapi_key
